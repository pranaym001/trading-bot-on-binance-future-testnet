# ─────────────────────────────────────────────────────────────────
# .env.example  —  copy this to .env and fill in your credentials
# ─────────────────────────────────────────────────────────────────

# ── Binance Futures TESTNET Credentials ──────────────────────────
# Get these from: https://testnet.binancefuture.com → API Management
BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here

# ── Endpoint (do NOT change for testnet) ─────────────────────────
BINANCE_BASE_URL=https://testnet.binancefuture.com

# ── Request Settings ─────────────────────────────────────────────
REQUEST_TIMEOUT=10        # seconds per HTTP request
MAX_RETRIES=3             # number of retry attempts on transient failure
RETRY_BACKOFF_BASE=1.5    # exponential backoff multiplier

# ── Logging ──────────────────────────────────────────────────────
LOG_DIR=logs              # directory for log files
LOG_LEVEL=DEBUG           # file log level  (DEBUG / INFO / WARNING / ERROR)
CONSOLE_LOG_LEVEL=INFO    # console log level

# ── Order History ─────────────────────────────────────────────────
HISTORY_CAPACITY=200      # in-memory circular buffer size

# ── Web UI (Flask dashboard) ──────────────────────────────────────
UI_HOST=127.0.0.1
UI_PORT=5000
UI_DEBUG=false
